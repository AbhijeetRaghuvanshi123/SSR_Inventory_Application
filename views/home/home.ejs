<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

  <header>
    <a href="/" class="logo">
      <div class="logo-icon">WH</div>
      WarehouseOS
    </a>
    <nav>
      <ul>
        <li><a href="/items/">Items</a></li>
        <li><a href="/categories/">Categories</a></li>
        <li><a href="/brands/">Brands</a></li>
        <li><a href="/" class="active">Users</a></li>
      </ul>
    </nav>
  </header>

  <main>

    <div class="page-header">
      <div>
        <h1 class="page-title">User <span>Registry</span></h1>
        <p class="page-subtitle">Warehouse operator accounts</p>
      </div>
      <a href="/new" class="btn-primary">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add User
      </a>
    </div>

    <div class="table-wrap">
      <div class="table-toolbar">
        <span class="table-toolbar-title">All Users</span>
        <span class="badge"><%= locals.users ? users.length : 0 %> records</span>
      </div>

      <% if (locals.users && users.length > 0) { %>
      <table>
        <thead>
          <tr>
            <th>User</th>
            <th>ID</th>
            <th>Email</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(user => { %>
          <tr>
            <td>
              <div class="user-cell">
                <div class="user-avatar"><%= user.username ? user.username[0].toUpperCase() : '?' %></div>
                <span class="user-name"><%= user.username %></span>
              </div>
            </td>
            <td><span class="user-id">#<%= user.id %></span></td>
            <td><span class="user-email"><%= user.email || '—' %></span></td>
            <td>
              <a href="/profile?id=<%= user.id %>" class="action-link">
                Profile
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } else { %>
      <div class="empty-state">
        <div class="empty-icon">👷</div>
        <h3>No Users Found</h3>
        <p>Add your first operator to get started.</p>
        <br>
        <a href="/new" class="btn-primary" style="margin-top:.5rem">Add User</a>
      </div>
      <% } %>
    </div>

  </main>

</body>
</html>