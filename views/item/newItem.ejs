<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

  <header>
    <a href="/" class="logo">
      <div class="logo-icon">WH</div>
      WarehouseOS
    </a>
    <nav>
      <ul>
        <li><a href="/items/" class="active">Items</a></li>
        <li><a href="/categories/">Categories</a></li>
        <li><a href="/brands/">Brands</a></li>
        <li><a href="/">Users</a></li>
      </ul>
    </nav>
  </header>

  <div class="form-page-wrap">
    <div class="form-container" style="max-width:620px">

      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb-sep">›</span>
        <a href="/items/">Items</a>
        <span class="breadcrumb-sep">›</span>
        <span>New Item</span>
      </nav>

      <div class="card">
        <div class="card-header">
          <h1 class="card-title">Add New <span>Item</span></h1>
        </div>
        <div class="card-body">

          <form action="/items/newItem" method="POST" autocomplete="off">

            <!-- Classification -->
            <p class="section-title">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 20h16M4 4h6l2 3h8v13H4z"/></svg>
              Classification
            </p>

            <div class="form-row">
              <div class="form-group">
                <label for="cat">Category</label>
                <div class="select-with-link">
                  <select name="category" id="cat" required>
                    <% categories.forEach(category => { %>
                      <option value="<%= category.id %>"><%= category.categoryname %></option>
                    <% }); %>
                  </select>
                </div>
                <p class="form-hint"><a href="/categories/newCategory" style="color:var(--green)">+ Add new category</a></p>
              </div>

              <div class="form-group">
                <label for="brand">Brand</label>
                <div class="select-with-link">
                  <select name="brand" id="brand" required>
                    <% brands.forEach(brand => { %>
                      <option value="<%= brand.id %>"><%= brand.brandname %></option>
                    <% }); %>
                  </select>
                </div>
                <p class="form-hint"><a href="/brands/newBrand" style="color:var(--green)">+ Add new brand</a></p>
              </div>
            </div>

            <!-- Item details -->
            <p class="section-title" style="margin-top:.5rem">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
              Item Details
            </p>

            <div class="form-group">
              <label for="name">Item Name</label>
              <input type="text" name="name" id="name" placeholder="e.g. M10 Hex Bolt 50mm" required />
            </div>

            <div class="form-group">
              <label for="desc">
                Description
                <span class="optional">(optional)</span>
              </label>
              <textarea name="description" id="desc" placeholder="Dimensions, specifications, notes…"></textarea>
            </div>

            <!-- Owner -->
            <p class="section-title" style="margin-top:.5rem">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              Created By
            </p>

            <div class="form-row">
              <div class="form-group">
                <label for="userid">User ID</label>
                <input type="text" name="userid" id="userid" value="<%= userId %>" readonly />
              </div>
              <div class="form-group">
                <label for="username">Username</label>
                <input type="text" name="username" id="username" value="<%= username %>" readonly />
              </div>
            </div>

            <div class="divider"></div>

            <div class="form-actions">
              <a href="/items/" class="btn-secondary">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
                Cancel
              </a>
              <button type="submit" class="btn-primary">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add Item
              </button>
            </div>

          </form>
        </div>
      </div>

    </div>
  </div>

</body>
</html>